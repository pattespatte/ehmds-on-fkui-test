{
  "name": "@ehmds/design-system",
  "version": "1.0.0",
  "description": "EHM Design System - A Vue 3 design system based on FKUI",
  "main": "dist/ehmds.umd.js",
  "module": "dist/ehmds.es.js",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --noEmit",
    "demo": "vite --config demo/vite.config.ts",
    "demo:preview": "vite preview --config demo/vite.config.ts",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src --ext .vue,.js,.ts",
    "lint:fix": "eslint src --ext .vue,.js,.ts --fix",
    "update:fkui-deps": "node scripts/update-fkui-deps.js"
  },
  "keywords": [
    "vue",
    "vue3",
    "design-system",
    "ui-components",
    "fkui",
    "ehmds"
  ],
  "author": "EHMDS Team",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.5.30"
  },
  "dependencies": {
    "@fkui/date": "^6.39.0",
    "@fkui/design": "^6.39.0",
    "@fkui/logic": "^6.39.0",
    "@fkui/theme-default": "^6.39.0",
    "@fkui/vue": "^6.39.0",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.0",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "10.1.0",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "^29.0.1",
    "prettier": "3.8.1",
    "sass": "1.98.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-static-copy": "^3.4.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pattespatte/ehmds-design-system.git"
  },
  "homepage": "https://github.com/pattespatte/ehmds-design-system#readme",
  "bugs": {
    "url": "https://github.com/pattespatte/ehmds-design-system/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/ehmds.es.js",
      "require": "./dist/ehmds.umd.js"
    },
    "./dist/style.css": "./dist/style.css"
  }
}
